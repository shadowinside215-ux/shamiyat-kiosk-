rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Robust Admin Check
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email != null && 
             (request.auth.token.email == "dragonballsam86@gmail.com" || 
              request.auth.token.email.toLower() == "dragonballsam86@gmail.com");
    }

    // Menu Item Validation
    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'image', 'createdAt', 'isAvailable', 'description'])
          && data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.description is string && data.description.size() <= 1000
          && data.price is number && data.price >= 0
          && data.category in ['Shawarma', 'Grills', 'Sandwiches', 'Sides', 'Desserts', 'Drinks']
          && data.image is string && data.image.size() <= 2000
          && data.createdAt == request.time
          && data.isAvailable is bool;
    }

    // Order Validation
    function isValidOrder(data) {
      return data.keys().hasAll(['orderNumber', 'items', 'total', 'status', 'type', 'createdAt'])
          && data.orderNumber is string && data.orderNumber.size() == 3
          && data.items is list && data.items.size() > 0 && data.items.size() <= 50
          && data.total is number && data.total >= 0
          && (data.status == 'pending')
          && data.type in ['dine-in', 'takeaway']
          && data.createdAt == request.time;
    }

    // Menu Collection Rules
    match /menu/{itemId} {
      // Menu is publicly readable for the kiosk
      allow read: if true; 
      
      // Only Admin can write to menu - relaxed validation for reliability
      allow create, update, delete: if isAdmin();
    }

    // Orders Collection Rules
    match /orders/{orderId} {
      // Allow customers to place orders
      allow create: if true;
      
      // Explicit read/write for Admin
      allow get, list, update, delete: if isAdmin();
    }
    
    // Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Managed manually or via console
    }
  }
}
