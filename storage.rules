rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read for menu images
      allow read: if true;
      
      // Allow write only for the authorized admin
      allow write: if request.auth != null 
                   && request.auth.token.email == "dragonballsam86@gmail.com"
                   && request.auth.token.email_verified == true;
    }
  }
}
